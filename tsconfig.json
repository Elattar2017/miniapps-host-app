{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest"],
    "baseUrl": ".",
    "paths": {
      "@attar/enterprise-module-sdk": ["../../index.ts"],
      "@sdk/*": ["../../src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "../../src/**/*.ts", "../../src/**/*.tsx", "../../index.ts"],
  "exclude": ["**/node_modules", "**/Pods"]
}
